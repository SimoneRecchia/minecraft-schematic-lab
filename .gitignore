# Ship the prebuilt bundle used by `npx github:` (git-spec installs use the committed
# tree, NOT the package.json `files` allowlist). These negations must come after the
# `dist/` rule above so the viewer copy under bundle/web/dist is tracked too.
!bundle/
!bundle/**
!bundle/web/dist/
!bundle/web/dist/**
